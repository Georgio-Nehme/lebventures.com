# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-central-1

# ── Cognito (JWT verification) ────────────────────────────────────────────────
COGNITO_POOL_ID=eu-central-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── DynamoDB tables ───────────────────────────────────────────────────────────
EVENTS_TABLE=lebventures-events
SUBS_TABLE=lebventures-subscriptions
REVIEWS_TABLE=lebventures-reviews
CONTACTS_TABLE=lebventures-contacts

# ── S3 (image uploads) ────────────────────────────────────────────────────────
IMAGES_BUCKET=lebventures-images-XXXXXXXXXXXX

# ── CORS — comma-separated list of allowed origins (use * to allow all) ───────
CORS_ORIGINS=https://lebventures.com,https://admin.lebventures.com
