---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'w-12 h-12' } = Astro.props;

function icon(paths: string) {
  return `<svg class="${className}" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${paths}</svg>`;
}

