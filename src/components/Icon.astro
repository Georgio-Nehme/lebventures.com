    <line x1="34.4" y1="7.4" x2="33" y2="9.8" stroke-width="0.8"/>
    <line x1="40.6" y1="13.6" x2="38.2" y2="15" stroke-width="0.8"/>
    <line x1="40.6" y1="34.4" x2="38.2" y2="33" stroke-width="0.8"/>
    <line x1="34.4" y1="40.6" x2="33" y2="38.2" stroke-width="0.8"/>
    <line x1="13.6" y1="40.6" x2="15" y2="38.2" stroke-width="0.8"/>
    <line x1="7.4" y1="34.4" x2="9.8" y2="33" stroke-width="0.8"/>
    <line x1="7.4" y1="13.6" x2="9.8" y2="15" stroke-width="0.8"/>
    <line x1="13.6" y1="7.4" x2="15" y2="9.8" stroke-width="0.8"/>
    <!-- Hour hand (pointing to ~10) -->
    <line x1="24" y1="24" x2="15" y2="13" stroke-width="2.5" stroke-linecap="round"/>
    <!-- Minute hand (pointing to ~2) -->
    <line x1="24" y1="24" x2="32" y2="10" stroke-width="1.8" stroke-linecap="round"/>
    <!-- Seconds hand (decorative, pointing to ~6) -->
    <line x1="24" y1="24" x2="24" y2="36" stroke-width="1"/>
    <!-- Center cap -->
    <circle cx="24" cy="24" r="2.5" fill="currentColor"/>
    <!-- Crown with leaf at top -->
    <path d="M21 6Q24 3 27 6" stroke-width="1.2"/>
  `),

  /* ── DECORATIVE / MISC ─────────────────────────────────────────── */

  mountain: icon(`
    <!-- Sky gradient hint: sun -->
    <circle cx="38" cy="10" r="6" fill="currentColor" fill-opacity="0.15"/>
    <!-- Sun rays -->
    <line x1="38" y1="2" x2="38" y2="1"/>
    <line x1="44" y1="4" x2="45" y2="3.3"/>
    <line x1="46" y1="10" x2="47" y2="10"/>
    <line x1="44" y1="16" x2="45" y2="16.7"/>
    <line x1="32" y1="4" x2="31" y2="3.3"/>
    <!-- Mountains fill -->
    <path d="M2 46L14 24L22 32L34 8L46 46Z" fill="currentColor" fill-opacity="0.1" stroke="none"/>
    <!-- Mountains -->
    <path d="M2 46L14 24L22 32L34 8L46 46"/>
    <!-- Snow cap -->
    <path d="M31 13L34 8L37 13"/>
    <!-- Ground line -->
    <line x1="2" y1="46" x2="46" y2="46"/>
    <!-- Rolling foothills -->
    <path d="M2 46Q12 40 18 44Q26 48 34 42Q40 38 46 44" stroke-width="1.2" opacity="0.4"/>
  `),

  scout: icon(`
    <!-- Shield outline fill -->
    <path d="M24 2L38 8L40 28Q40 42 24 46Q8 42 8 28L10 8Z" fill="currentColor" fill-opacity="0.08" stroke="none"/>
    <!-- Shield outline -->
    <path d="M24 2L38 8L40 28Q40 42 24 46Q8 42 8 28L10 8Z"/>
    <!-- Fleur-de-lis: center petal -->
    <path d="M24 32Q21 24 21 18Q21 12 24 10Q27 12 27 18Q27 24 24 32Z" fill="currentColor" fill-opacity="0.2"/>
    <path d="M24 32Q21 24 21 18Q21 12 24 10Q27 12 27 18Q27 24 24 32Z"/>
    <!-- Left petal -->
    <path d="M24 28Q18 26 14 26Q10 24 11 20Q12 16 16 17Q20 18 22 22"/>
    <!-- Right petal -->
    <path d="M24 28Q30 26 34 26Q38 24 37 20Q36 16 32 17Q28 18 26 22"/>
    <!-- Cross bar -->
    <line x1="18" y1="26" x2="30" y2="26" stroke-width="1.5"/>
    <!-- Base of fleur -->
    <path d="M21 32Q24 34 27 32"/>
    <!-- Stars on shield -->
    <circle cx="14" cy="38" r="1.5" fill="currentColor" fill-opacity="0.5" stroke="none"/>
    <circle cx="34" cy="38" r="1.5" fill="currentColor" fill-opacity="0.5" stroke="none"/>
  `),

  peak: icon(`
    <!-- Sky fill -->
    <rect x="0" y="0" width="48" height="48" fill="currentColor" fill-opacity="0.04" stroke="none"/>
    <!-- Main peak fill -->
    <path d="M24 4L44 44L4 44Z" fill="currentColor" fill-opacity="0.12" stroke="none"/>
    <!-- Main peak -->
    <path d="M24 4L44 44H4Z"/>
    <!-- Snow cap fill -->
    <path d="M24 4L14 20L24 17L34 20Z" fill="currentColor" fill-opacity="0.25" stroke="none"/>
    <!-- Snow cap outline -->
    <path d="M14 20L24 4L34 20L24 17Z"/>
    <!-- Left smaller peak -->
    <path d="M4 44L12 28L20 44"/>
    <!-- Stars -->
    <circle cx="8" cy="10" r="1.2" fill="currentColor" stroke="none"/>
    <circle cx="40" cy="8" r="1" fill="currentColor" stroke="none"/>
    <circle cx="36" cy="16" r="0.8" fill="currentColor" stroke="none"/>
    <circle cx="14" cy="6" r="1" fill="currentColor" stroke="none"/>
    <!-- Moon -->
    <path d="M40 22A6 6 0 1 1 40 34A4.5 4.5 0 1 0 40 22Z" fill="currentColor" fill-opacity="0.2" stroke="currentColor" stroke-width="1"/>
  `),

  /* ── EVENTS ────────────────────────────────────────────────────── */

  calendar: icon(`
    <!-- Calendar body fill -->
    <rect x="4" y="10" width="40" height="36" rx="3" fill="currentColor" fill-opacity="0.08" stroke="none"/>
    <!-- Calendar body -->
    <rect x="4" y="10" width="40" height="36" rx="3"/>
    <!-- Header bar -->
    <rect x="4" y="10" width="40" height="12" rx="3" fill="currentColor" fill-opacity="0.15" stroke="none"/>
    <path d="M4 18L44 18"/>
    <!-- Binding pegs -->
    <line x1="14" y1="6" x2="14" y2="14" stroke-width="2.5"/>
    <line x1="34" y1="6" x2="34" y2="14" stroke-width="2.5"/>
    <!-- Day grid: 3 cols x 3 rows -->
    <!-- Row 1 -->
    <circle cx="14" cy="28" r="3" fill="currentColor" fill-opacity="0.25" stroke="none"/>
    <rect x="11" y="25" width="6" height="6" rx="1.5" fill="currentColor" fill-opacity="0.25" stroke="none"/>
    <rect x="21" y="25" width="6" height="6" rx="1.5" fill="currentColor" fill-opacity="0.12" stroke="none"/>
    <rect x="31" y="25" width="6" height="6" rx="1.5" fill="currentColor" fill-opacity="0.12" stroke="none"/>
    <!-- Row 2 -->
    <rect x="11" y="34" width="6" height="6" rx="1.5" fill="currentColor" fill-opacity="0.12" stroke="none"/>
    <rect x="21" y="34" width="6" height="6" rx="1.5" fill="currentColor" fill-opacity="0.12" stroke="none"/>
    <rect x="31" y="34" width="6" height="6" rx="1.5" fill="currentColor" fill-opacity="0.12" stroke="none"/>
    <!-- Highlight first cell (today/event) -->
    <rect x="11" y="25" width="6" height="6" rx="1.5" stroke-width="1.5"/>
  `),

  workshop: icon(`
    <!-- Notepad/clipboard base -->
    <rect x="10" y="8" width="28" height="36" rx="2" fill="currentColor" fill-opacity="0.08"/>
    <rect x="10" y="8" width="28" height="36" rx="2"/>
    <!-- Clipboard top clip -->
    <rect x="18" y="4" width="12" height="8" rx="2"/>
    <!-- Lines of text -->
    <line x1="15" y1="22" x2="33" y2="22"/>
    <line x1="15" y1="28" x2="33" y2="28"/>
    <line x1="15" y1="34" x2="25" y2="34"/>
    <!-- Pencil writing on last line -->
    <path d="M27 34L34 27L37 30L30 37Z" fill="currentColor" fill-opacity="0.2"/>
    <path d="M27 34L34 27"/>
    <path d="M34 27L37 30"/>
    <path d="M27 34L30 37"/>
    <line x1="37" y1="30" x2="38" y2="26" stroke-width="1.2"/>
    <!-- Tick/check on first line -->
    <path d="M15 17L17 19L21 15" stroke-width="1.5"/>
  `),
};
---

<Fragment set:html={icons[name] ?? ''} />
