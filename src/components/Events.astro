---
import Icon from './Icon.astro';
import { getEvents } from '../data/events';
import type { Event } from '../data/events';

interface Props {
  limit?: number;          // show only N events (homepage snippet)
  showAll?: boolean;       // show the "View all" footer link
}

const { limit, showAll = true } = Astro.props;

const allEvents = await getEvents();
const events = limit ? allEvents.slice(0, limit) : allEvents;

// Maps event type to the icon name used in Icon.astro
const typeIcon: Record<Event['type'], string> = {
  hiking:   'hiking',
  climbing: 'climbing',
  camping:  'camping',
  heritage: 'heritage',
  canyoning:'canyoning',
  biking:   'biking',
  workshop: 'workshop',
  water:    'water',
  snow:     'snow',
  leisure:  'leisure',
  kids:     'kids',
};

const difficultyColor: Record<Event['difficulty'], string> = {
  Easy:       'bg-green-100 text-green-800',
  Moderate:   'bg-yellow-100 text-yellow-800',
  Challenging:'bg-orange-100 text-orange-800',
  Expert:     'bg-red-100 text-red-800',
};

function formatDate(iso: string) {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' });
}

function formatMonth(iso: string) {
  return new Date(iso + 'T00:00:00').toLocaleDateString('en-GB', { month: 'short' }).toUpperCase();
}

function formatDay(iso: string) {
  return new Date(iso + 'T00:00:00').getDate();
}

function spotsClass(left: number, total: number) {
  const pct = left / total;
  if (pct === 0) return 'text-red-600';
  if (pct <= 0.3) return 'text-orange-500';
  return 'text-brand-primary';
}
---

<section id="events" class="py-20 bg-brand-sky/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <span class="inline-block text-xs font-bold text-brand-primary uppercase tracking-widest mb-3">What's Coming Up</span>
      <h2 class="section-heading">Upcoming Events</h2>
      <p class="section-subheading mx-auto">
        Join a scheduled adventure or workshop. All trips are small-group and led by our certified founders.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {events.map(event => (
        <article class="group bg-white rounded-2xl border border-brand-sky overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">

          <!-- Photo header (when image provided) OR solid branded header -->
          {event.image ? (
            <div class="relative h-48 overflow-hidden shrink-0">
              <img
                src={event.image}
                alt={event.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/85 via-brand-dark/30 to-transparent" />
              <!-- Date badge (top-left) -->
              <div class="absolute top-3 left-3 bg-white rounded-xl w-14 text-center py-1.5 shadow-md">
                <div class="text-[0.6rem] font-bold text-brand-primary uppercase tracking-widest leading-none">
                  {formatMonth(event.date)}
                </div>
                <div class="text-2xl font-heading font-bold text-brand-dark leading-none mt-0.5">
                  {formatDay(event.date)}
                </div>
              </div>
              <!-- Type + title (bottom) -->
              <div class="absolute bottom-0 left-0 right-0 px-4 pb-3">
                <div class="flex items-center gap-2 mb-0.5">
                  <span class="text-brand-lime opacity-90">
                    <Icon name={typeIcon[event.type]} class="w-4 h-4" />
                  </span>
                  <span class="text-xs font-semibold text-white/70 capitalize">{event.type}</span>
                </div>
                <h3 class="font-heading font-bold text-white text-base leading-tight truncate">
                  {event.title}
                </h3>
              </div>
            </div>
          ) : (
            <div class="bg-brand-primary px-5 py-4 flex items-center gap-4 shrink-0">
              <!-- Calendar date block -->
              <div class="shrink-0 bg-white rounded-xl w-14 text-center py-1.5 shadow-sm">
                <div class="text-[0.6rem] font-bold text-brand-primary uppercase tracking-widest leading-none">
                  {formatMonth(event.date)}
                </div>
                <div class="text-2xl font-heading font-bold text-brand-dark leading-none mt-0.5">
                  {formatDay(event.date)}
                </div>
              </div>
              <!-- Type icon + title -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-brand-lime opacity-90">
                    <Icon name={typeIcon[event.type]} class="w-5 h-5" />
                  </span>
                  <span class="text-xs font-semibold text-white/70 capitalize">{event.type}</span>
                </div>
                <h3 class="font-heading font-bold text-white text-base leading-tight truncate">
                  {event.title}
                </h3>
              </div>
            </div>
          )}

          <!-- Card body -->
          <div class="px-5 py-4 flex flex-col flex-1 gap-3">

            <!-- Meta row -->
            <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500">
              <span class="flex items-center gap-1">
                <!-- Clock icon (inline mini) -->
                <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <circle cx="8" cy="8" r="6.5"/>
                  <path d="M8 5v3.5L10.5 10"/>
                </svg>
                {event.time} · {event.duration}
              </span>
              <span class="flex items-center gap-1">
                <!-- Pin icon (inline mini) -->
                <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <path d="M8 1.5C5.5 1.5 3.5 3.5 3.5 6C3.5 9.5 8 14.5 8 14.5C8 14.5 12.5 9.5 12.5 6C12.5 3.5 10.5 1.5 8 1.5Z"/>
                  <circle cx="8" cy="6" r="2"/>
                </svg>
                {event.location}
              </span>
            </div>

            <!-- Description -->
            <p class="text-sm text-gray-600 leading-relaxed line-clamp-3 flex-1">
              {event.description}
            </p>

            <!-- Highlights -->
            <ul class="space-y-1">
              {event.highlights.slice(0, 3).map(h => (
                <li class="flex items-start gap-2 text-xs text-gray-600">
                  <svg class="w-3.5 h-3.5 mt-0.5 shrink-0 text-brand-lime" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M13.5 3.5L6 11L2.5 7.5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {h}
                </li>
              ))}
            </ul>

            <!-- Footer row: difficulty + spots + price -->
            <div class="flex items-center justify-between pt-3 border-t border-brand-sky mt-auto">
              <div class="flex items-center gap-2">
                <span class:list={['text-xs font-bold px-2 py-0.5 rounded-full', difficultyColor[event.difficulty]]}>
                  {event.difficulty}
                </span>
                <span class:list={['text-xs font-semibold', spotsClass(event.spotsLeft, event.spots)]}>
                  {event.spotsLeft === 0
                    ? 'Fully booked'
                    : `${event.spotsLeft} spot${event.spotsLeft === 1 ? '' : 's'} left`}
                </span>
              </div>
              <div class="text-right">
                <span class="text-lg font-heading font-bold text-brand-primary">
                  {event.price === 0 ? 'Free' : `$${event.price}`}
                </span>
                {event.price > 0 && <span class="text-xs text-gray-400 block leading-none">per person</span>}
              </div>
            </div>

            <!-- CTA -->
            <a
              href={event.spotsLeft === 0 ? '#' : `/events/${event.id}`}
              class:list={[
                'w-full text-center text-sm font-bold py-2.5 rounded-xl transition-colors duration-200',
                event.spotsLeft === 0
                  ? 'bg-gray-100 text-gray-400 cursor-not-allowed pointer-events-none'
                  : 'bg-brand-primary text-white hover:bg-brand-olive',
              ]}
            >
              {event.spotsLeft === 0 ? 'Fully Booked' : 'Reserve My Spot →'}
            </a>

          </div>
        </article>
      ))}
    </div>

    {showAll && limit && allEvents.length > limit && (
      <div class="text-center mt-12">
        <a href="/events" class="btn-outline">View All Events ({allEvents.length})</a>
      </div>
    )}

  </div>
</section>
