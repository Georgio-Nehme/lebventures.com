            <a href="mailto:lebventures.lebanon@gmail.com" class="hover:text-brand-gold transition-colors">
              lebventures.lebanon@gmail.com
            </a>
          </li>
          <li>
            <a href="tel:+96170050590" class="hover:text-brand-gold transition-colors">+961 70-050590</a>
          </li>
          <li>Byblos (Amchit), Lebanon</li>
          <li class="flex gap-4 pt-2">
