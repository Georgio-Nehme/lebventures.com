<footer class="bg-brand-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex flex-col leading-tight mb-4">
          <span class="font-heading font-bold text-xl text-white tracking-wider uppercase">LebVentures</span>
          <span class="font-heading italic text-[0.6rem] text-brand-lime tracking-wide -mt-0.5">for the love of nature.</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Community-driven sustainable tourism rooted in the spirit of scouting — guiding adventurers through the heart of Lebanon.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-heading font-bold text-brand-lime mb-4 uppercase tracking-wider text-sm">Explore</h4>
        <ul class="space-y-2 text-sm text-gray-300">
          <li><a href="/adventures" class="hover:text-brand-gold transition-colors">Adventures</a></li>
          <li><a href="/events" class="hover:text-brand-gold transition-colors">Events</a></li>
          <li><a href="/sustainable-tourism" class="hover:text-brand-gold transition-colors">Sustainable Tourism</a></li>
          <li><a href="/about" class="hover:text-brand-gold transition-colors">About Us</a></li>
          <li><a href="/contact" class="hover:text-brand-gold transition-colors">Contact</a></li>
        </ul>
      </div>

