---
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description, keywords, ogImage, ogType } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://lebventures.com/#organization',
      name: 'LebVentures',
      url: 'https://lebventures.com',
      description: 'Family-founded adventure tour operator offering inclusive outdoor experiences across Lebanon — hiking, camping, water activities, winter adventures, and kids educational trips.',
      foundingDate: '2019',
      founder: [
        { '@type': 'Person', name: 'Pierre Abboud' },
        { '@type': 'Person', name: 'Gioia Wehbe' },
      ],
      areaServed: 'Lebanon',
      email: 'lebventures.lebanon@gmail.com',
      telephone: '+961-70-050590',
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer service',
        telephone: '+961-70-050590',
        email: 'lebventures.lebanon@gmail.com',
        availableLanguage: ['English', 'Arabic', 'French'],
      },
      sameAs: [
        'https://www.instagram.com/lebventures',
        'https://www.facebook.com/lebventures',
      ],
    },
    {
      '@type': 'TouristInformationCenter',
      '@id': 'https://lebventures.com/#business',
      name: 'LebVentures',
      url: 'https://lebventures.com',
      description: 'Family-founded sustainable adventure tourism guiding adventurers through Lebanon\'s trails, cedars, ruins, and landscapes — based in Byblos.',
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'LB',
        addressLocality: 'Byblos (Amchit)',
        addressRegion: 'North Governorate',
        streetAddress: 'El Tine Street',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: '34.1217',
        longitude: '35.6516',
      },
      telephone: '+961-70-050590',
      email: 'lebventures.lebanon@gmail.com',
      touristType: ['Hikers', 'Families', 'Nature enthusiasts', 'Adventure travelers', 'Eco-tourists', 'Corporate groups'],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://lebventures.com/#website',
      url: 'https://lebventures.com',
      name: 'LebVentures',
      description: 'For the Love of Nature.',
      publisher: { '@id': 'https://lebventures.com/#organization' },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      keywords={keywords}
      ogImage={ogImage}
      ogType={ogType}
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
