---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Adventures from '../components/Adventures.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Adventures in Lebanon"
  description="Explore LebVentures' full range of outdoor adventures in Lebanon — hiking, rock climbing, camping, kayaking, snowshoeing, mountain biking, caving, stargazing, and kids educational experiences for all ages. Based in Byblos."
  keywords="hiking Lebanon, rock climbing Lebanon, camping Lebanon, kayaking Lebanon, snowshoeing Lebanon, mountain biking Lebanon, caving Lebanon, kids outdoor activities Lebanon, adventure tours Byblos, LebVentures"
>
  <Navbar />
  <main>
    <Hero
      tagline="Choose Your Adventure"
      heading="Adventures for<br />Every Explorer"
      subheading="Nine categories of guided outdoor experiences spanning Lebanon's most spectacular terrain — from beginner-friendly family hikes to multi-day wilderness expeditions and winter snowshoeing."
      primaryCta={{ label: 'Book an Adventure', href: '/contact' }}
    />
    <Adventures />
  </main>
  <Footer />
</BaseLayout>
