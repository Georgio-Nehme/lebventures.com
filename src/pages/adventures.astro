---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Adventures from '../components/Adventures.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Adventures in Lebanon"
  description="Explore LebVentures' full range of outdoor adventures in Lebanon — hiking, rock climbing, camping, canyoning, mountain biking, and heritage sightseeing tours for all levels."
  keywords="hiking Lebanon, rock climbing Lebanon, camping Lebanon, canyoning Lebanon, mountain biking Lebanon, heritage tours Lebanon, outdoor adventures Lebanon"
>
  <Navbar />
  <main>
    <Hero
      tagline="Choose Your Adventure"
      heading="Adventures for<br />Every Explorer"
      subheading="Six categories of guided outdoor experiences spanning Lebanon's most spectacular terrain — from beginner-friendly day hikes to multi-day wilderness expeditions."
      primaryCta={{ label: 'Book an Adventure', href: '/contact' }}
    />
    <Adventures />
  </main>
  <Footer />
</BaseLayout>
