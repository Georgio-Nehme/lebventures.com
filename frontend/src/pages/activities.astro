---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import { getEvents } from '../../data/events';
import type { Event } from '../../data/events';
import '../../styles/global.css';

const allEvents = await getEvents();
const today = new Date();
today.setHours(0, 0, 0, 0);

const pastEvents = allEvents
  .filter(e => new Date(e.date + 'T00:00:00') < today)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const typeIcon: Record<Event['type'], string> = {
  hiking:   'hiking',
  climbing: 'climbing',
  camping:  'camping',
  heritage: 'heritage',
  canyoning:'canyoning',
  biking:   'biking',
  workshop: 'workshop',
  water:    'water',
  snow:     'snow',
  leisure:  'leisure',
  kids:     'kids',
};

function formatDate(iso: string) {
  return new Date(iso + 'T00:00:00').toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}
---

<BaseLayout
  title="Past Adventures — LebVentures"
  description="Browse completed LebVentures adventures across Lebanon. Read participant reviews and share your own experience from past hikes, camping trips, and workshops."
  keywords="past adventures Lebanon, LebVentures reviews, hiking reviews Lebanon, adventure experiences Lebanon"
>
  <Navbar />
  <main class="pt-16">

    <!-- Page header -->
    <div class="bg-brand-primary text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <span class="inline-block text-xs font-bold text-brand-gold uppercase tracking-widest mb-3">Memories Made</span>
        <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">Past Adventures</h1>
        <p class="text-white/80 text-lg max-w-2xl leading-relaxed">
          Every adventure leaves a mark. Browse our completed trips, read what participants had to say, and add your own review if you joined us.
        </p>
      </div>
    </div>

    <section class="py-20 bg-brand-sky/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        {pastEvents.length === 0 ? (
          <div class="text-center py-24 text-gray-400">
            <p class="text-lg font-medium">No past adventures yet — check back soon!</p>
            <a href="/events" class="btn-primary mt-6 inline-block">See Upcoming Events</a>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            {pastEvents.map(event => (
              <article class="group bg-white rounded-2xl border border-brand-sky overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">

                {event.image ? (
                  <div class="relative h-48 overflow-hidden shrink-0">
                    <img
                      src={event.image}
                      alt={event.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 grayscale-[20%]"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/85 via-brand-dark/30 to-transparent" />
                    <div class="absolute top-3 left-3 bg-brand-gold text-brand-dark rounded-lg px-2 py-1 text-[0.65rem] font-bold uppercase tracking-widest">
                      Completed
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 px-4 pb-3">
                      <div class="flex items-center gap-2 mb-0.5">
                        <span class="text-brand-lime opacity-90">
                          <Icon name={typeIcon[event.type]} class="w-4 h-4" />
                        </span>
                        <span class="text-xs font-semibold text-white/70 capitalize">{event.type}</span>
                      </div>
                      <h3 class="font-heading font-bold text-white text-base leading-tight truncate">{event.title}</h3>
                    </div>
                  </div>
                ) : (
                  <div class="bg-brand-dark px-5 py-4 flex items-center gap-4 shrink-0">
                    <div class="shrink-0 bg-brand-gold/20 rounded-xl p-2 text-brand-gold">
                      <Icon name={typeIcon[event.type]} class="w-8 h-8" />
                    </div>
                    <div class="flex-1 min-w-0">
                      <span class="text-[0.65rem] font-bold text-brand-gold uppercase tracking-widest">Completed · {event.type}</span>
                      <h3 class="font-heading font-bold text-white text-base leading-tight truncate">{event.title}</h3>
                    </div>
                  </div>
                )}

                <div class="px-5 py-4 flex flex-col flex-1 gap-3">
                  <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500">
                    <span>📅 {formatDate(event.date)}</span>
                    <span>📍 {event.location}</span>
                  </div>
                  <p class="text-sm text-gray-600 leading-relaxed line-clamp-2 flex-1">{event.description}</p>

                  <!-- Review summary loaded by JS -->
                  <div class="review-summary text-xs text-gray-400 min-h-[1.25rem]" data-event-id={event.id}>
                    Loading reviews…
                  </div>

                  <a
                    href={`/events/${event.id}`}
                    class="w-full text-center text-sm font-bold py-2.5 rounded-xl bg-brand-primary/10 text-brand-primary hover:bg-brand-primary hover:text-white border border-brand-primary/20 transition-colors duration-200"
                  >
                    View & Leave a Review →
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}

        <div class="text-center mt-16">
          <p class="text-sm text-gray-500 mb-4">Ready for your next adventure?</p>
          <a href="/events" class="btn-primary">See Upcoming Events</a>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';

  document.querySelectorAll<HTMLElement>('.review-summary').forEach(async (el) => {
    const eventId = el.dataset.eventId;
    if (!eventId) { el.textContent = ''; return; }
    try {
      const res = await fetch(`${API}/events/${eventId}/reviews/public`);
      if (!res.ok) { el.textContent = ''; return; }
      const reviews: { rating: number }[] = await res.json();
      if (reviews.length === 0) {
        el.textContent = 'No reviews yet — be the first!';
      } else {
        const avg = reviews.reduce((s, r) => s + r.rating, 0) / reviews.length;
        const stars = '★'.repeat(Math.round(avg)) + '☆'.repeat(5 - Math.round(avg));
        el.innerHTML = `<span class="text-amber-500">${stars}</span> <span class="text-gray-500">${avg.toFixed(1)} · ${reviews.length} review${reviews.length === 1 ? '' : 's'}</span>`;
      }
    } catch {
      el.textContent = '';
    }
  });
</script>
