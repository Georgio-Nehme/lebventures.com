<!-- ── Route Map ─────────────────────────────────────────────────── -->
<script is:inline>
  document.addEventListener('ev:loaded', function() {
    (function initMap() {
      var mapEl = document.getElementById('event-map');
      if (!mapEl) return;
      if (typeof L === 'undefined') { setTimeout(initMap, 50); return; }

      var lat   = parseFloat(mapEl.dataset.lat);
      var lng   = parseFloat(mapEl.dataset.lng);
      var title = mapEl.dataset.title;
      var loc   = mapEl.dataset.location;
      var trail = mapEl.dataset.trail;
      var hasCoords = isFinite(lat) && isFinite(lng) && lat !== 0 && lng !== 0;

      var initCenter = hasCoords ? [lat, lng] : [33.85, 35.86];
      var map = L.map(mapEl, { scrollWheelZoom: false }).setView(initCenter, hasCoords ? 13 : 8);

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors', maxZoom: 18,
      }).addTo(map);

      if (hasCoords) {
        var pin = L.divIcon({
          html: '<div style="width:28px;height:28px;background:#1B4332;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.35)"></div>',
          iconSize: [28, 28], iconAnchor: [14, 28], popupAnchor: [0, -30], className: '',
        });
        L.marker([lat, lng], { icon: pin })
          .addTo(map)
          .bindPopup('<strong style="font-size:13px">' + title + '</strong><br><span style="font-size:11px;color:#666">' + loc + '</span><br><a href="https://www.google.com/maps?q=' + lat + ',' + lng + '" target="_blank" rel="noopener noreferrer" style="font-size:11px;color:#1B4332;font-weight:600;margin-top:4px;display:inline-block">📍 Open in Google Maps →</a>')
          .openPopup();
      }

      if (trail) {
        fetch(trail)
          .then(function(r) { return r.text(); })
          .then(function(xml) {
            var doc = new DOMParser().parseFromString(xml, 'text/xml');
            var pts = Array.from(doc.querySelectorAll('trkpt'));
            if (!pts.length) pts = Array.from(doc.querySelectorAll('rtept'));
            if (!pts.length) return;
            var latlngs = pts.map(function(p) { return [parseFloat(p.getAttribute('lat')), parseFloat(p.getAttribute('lon'))]; }).filter(function(ll) { return isFinite(ll[0]) && isFinite(ll[1]); });
            if (!latlngs.length) return;
            window._trailStartLat = latlngs[0][0];
            window._trailStartLng = latlngs[0][1];
            var polyline = L.polyline(latlngs, { color: '#1B4332', weight: 4, opacity: 0.85 }).addTo(map);
            map.fitBounds(polyline.getBounds(), { padding: [40, 40] });
          })
          .catch(function(e) { console.error('GPX load error:', e); });
      }
    })();
  });
</script>
