---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import EventReviews from '../../components/EventReviews.astro';
import '../../styles/global.css';

// Generate a single placeholder page at /events/_/
// Nginx falls back to this shell for any event URL not pre-built.
export function getStaticPaths() {
  return [{ params: { id: '_' } }];
}

const apiUrl = import.meta.env.PUBLIC_API_URL;
const allTypes = ['hiking','climbing','camping','heritage','canyoning','biking','workshop','water','snow','leisure','kids'] as const;

---

<BaseLayout title="Loading Event — LebVentures" description="Join a LebVentures adventure in Lebanon.">
  <Navbar />
  <main class="pt-16">

    <!-- Loading state -->
    <div id="ev-loading" class="min-h-[60vh] flex flex-col items-center justify-center gap-4 py-24">
      <div class="w-10 h-10 border-4 border-brand-primary/30 border-t-brand-primary rounded-full animate-spin"></div>
      <p class="text-sm text-gray-400">Loading event…</p>
    </div>

    <!-- Error state -->
    <div id="ev-error" class="hidden min-h-[60vh] flex flex-col items-center justify-center gap-4 py-24 text-center px-4">
      <div class="text-5xl">😕</div>
      <h2 class="text-xl font-heading font-bold text-brand-dark">Event not found</h2>
      <p class="text-gray-500 text-sm">This event may no longer be available.</p>
      <a href="/events" class="btn-outline mt-2">Browse All Events</a>
    </div>

    <!-- Page content (hidden until loaded) -->
    <div id="ev-content" class="hidden">

      <!-- Page header -->
      <div class="bg-brand-primary text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <a href="/events" class="inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium mb-6 transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 3L5 8L10 13"/>
            </svg>
            Back to all events
          </a>
          <div class="flex flex-wrap items-start gap-6">
            <!-- All type icons pre-rendered; JS shows the correct one -->
            <div class="shrink-0 bg-white/10 rounded-2xl p-4 text-brand-lime">
              {allTypes.map(t => (
                <div class="ev-icon hidden" data-type={t}>
                  <Icon name={t} class="w-14 h-14" />
                </div>
              ))}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span id="ev-type-badge" class="text-xs font-bold text-brand-gold uppercase tracking-widest capitalize"></span>
                <span class="text-white/30">·</span>
                <span id="ev-diff-badge" class="text-xs font-bold px-2 py-0.5 rounded-full"></span>
                <span id="ev-full-badge" class="hidden text-xs font-bold bg-red-500 text-white px-2 py-0.5 rounded-full">Fully Booked</span>
              </div>
              <h1 id="ev-title" class="text-3xl md:text-4xl font-heading font-bold leading-tight mb-3"></h1>
              <p id="ev-desc" class="text-white/75 text-lg leading-relaxed max-w-2xl"></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick-info strip -->
      <div class="bg-brand-dark text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-white/10">
            <div class="px-4 py-4 flex flex-col gap-0.5">
              <span class="text-[0.65rem] font-bold text-brand-gold uppercase tracking-widest">Date</span>
              <span id="ev-date" class="text-sm font-semibold text-white"></span>
            </div>
            <div class="px-4 py-4 flex flex-col gap-0.5">
              <span class="text-[0.65rem] font-bold text-brand-gold uppercase tracking-widest">Start time</span>
              <span id="ev-time" class="text-sm font-semibold text-white"></span>
            </div>
            <div class="px-4 py-4 flex flex-col gap-0.5">
              <span class="text-[0.65rem] font-bold text-brand-gold uppercase tracking-widest">Location</span>
              <span id="ev-location" class="text-sm font-semibold text-white"></span>
            </div>
            <div class="px-4 py-4 flex flex-col gap-0.5">
              <span class="text-[0.65rem] font-bold text-brand-gold uppercase tracking-widest">Price</span>
              <span id="ev-price" class="text-sm font-semibold text-white"></span>
            </div>
        </div>
      </div>
    </div>

    <!-- Event photo (hidden until JS sets src) -->
    <div id="ev-photo-wrap" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 hidden">
      <div class="rounded-3xl overflow-hidden h-72 md:h-[460px] shadow-lg">
        <img id="ev-photo" src="" alt="" class="w-full h-full object-cover" loading="eager" />
      </div>
    </div>

    <!-- Route Map (hidden until JS decides to show it) -->
    <div id="ev-map-wrap" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 hidden">
      <div class="relative rounded-3xl overflow-hidden border border-brand-sky shadow-md bg-brand-sky/20">
        <div id="event-map" style="height: 400px;"></div>
      </div>
      <p class="text-xs text-gray-400 text-right mt-1.5 pr-1">
        Map data © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer" class="hover:underline">OpenStreetMap</a> contributors
        <span id="ev-trail-note" class="hidden"> · Route overlay included</span>
      </p>
    </div>

    <!-- Main content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid lg:grid-cols-5 gap-12 items-start">

        <!-- ── LEFT: Event details ───────────────────────────────── -->
        <div class="lg:col-span-3 space-y-10">

          <!-- What's included -->
          <section aria-labelledby="highlights-heading">
            <h2 id="highlights-heading" class="text-xl font-heading font-bold text-brand-primary mb-5">What's Included</h2>
            <ul id="ev-highlights" class="grid sm:grid-cols-2 gap-3"></ul>
          </section>

          <!-- Event details -->
          <section aria-labelledby="details-heading">
            <h2 id="details-heading" class="text-xl font-heading font-bold text-brand-primary mb-5">Event Details</h2>
            <dl id="ev-details" class="grid sm:grid-cols-2 gap-4"></dl>
          </section>

          <!-- Weather Forecast -->
          <section aria-labelledby="weather-heading">
            <h2 id="weather-heading" class="text-xl font-heading font-bold text-brand-primary mb-4 flex items-center gap-2">
              🌤 Weather Forecast
              <span id="ev-weather-loc" class="text-xs font-normal font-sans text-gray-400"></span>
            </h2>
            <div
              id="weather-widget"
              data-lat=""
              data-lng=""
              data-date=""
              data-location=""
              class="p-5 rounded-2xl border border-brand-sky bg-white"
            >
              <div id="weather-loading" class="py-6 text-center">
                <div class="text-3xl mb-2">🌤</div>
                <p class="text-sm text-gray-400">Fetching forecast…</p>
              </div>
              <div id="weather-content" class="hidden"></div>
              <div id="weather-error" class="hidden py-6 text-center">
                <p class="text-sm text-gray-400">Forecast unavailable — try again later.</p>
                <a id="ev-wttr-link" href="#" target="_blank" rel="noopener noreferrer" class="text-xs text-brand-primary hover:underline mt-1 inline-block">Check weather →</a>
              </div>
            </div>
          </section>

          <!-- Availability bar -->
          <section aria-labelledby="availability-heading">
            <h2 id="availability-heading" class="text-xl font-heading font-bold text-brand-primary mb-4">Availability</h2>
            <div class="p-5 rounded-2xl border border-brand-sky bg-white">
              <div class="flex justify-between items-center mb-2">
                <span id="ev-avail-text" class="text-sm font-medium text-gray-600"></span>
                <span id="ev-avail-pct" class="text-sm font-bold text-brand-primary"></span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                <div id="ev-avail-bar" class="h-2.5 rounded-full transition-all bg-brand-primary" style="width:0%"></div>
              </div>
              <p class="text-xs text-gray-400 mt-2">Spots fill fast — reserve early to secure your place.</p>
            </div>
          </section>

        </div>

        <!-- ── RIGHT: Reservation form ────────────────────────────── -->
        <aside id="ev-reservation-aside" class="lg:col-span-2 lg:sticky lg:top-24">
          <div class="bg-white rounded-3xl border border-brand-sky shadow-xl overflow-hidden">

            <!-- Form header -->
            <div class="bg-brand-primary px-6 py-5">
              <h2 id="ev-form-title" class="font-heading font-bold text-white text-xl">Reserve Your Spot</h2>
              <p id="ev-form-subtitle" class="text-white/70 text-sm mt-1"></p>
            </div>

            <!-- Price summary -->
            <div id="ev-price-row" class="px-6 py-3 bg-brand-sky/30 border-b border-brand-sky flex justify-between items-center">
              <span class="text-sm text-gray-600">Price per person</span>
              <span id="ev-price-display" class="font-heading font-bold text-brand-primary text-lg"></span>
            </div>

            <!-- Form body -->
            <form
              id="reservation-form"
              class="px-6 py-6 space-y-5"
              action="#"
              method="POST"
              novalidate
            >
              <input type="hidden" name="event_id" id="inp-event-id" value="" />
              <input type="hidden" name="event_title" id="inp-event-title" value="" />
              <input type="hidden" name="event_date" id="inp-event-date" value="" />

              <div>
                <label for="res-name" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-1.5">Full Name *</label>
                <input
                  type="text"
                  id="res-name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white"
                />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4">
                <div>
                  <label for="res-email" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-1.5">Email Address *</label>
                  <input
                    type="email"
                    id="res-email"
                    name="email"
                    required
                    placeholder="you@example.com"
                    class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white"
                  />
                </div>

                <div>
                  <label for="res-phone" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-1.5">Phone / WhatsApp *</label>
                  <input
                    type="tel"
                    id="res-phone"
                    name="phone"
                    required
                    placeholder="+961 XX XXX XXX"
                    class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white"
                  />
                </div>
              </div>

              <div>
                <label for="res-group" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-1.5">Group Size</label>
                <select
                  id="res-group"
                  name="group_size"
                  class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white"
                >
                  <option value="">How many people?</option>
                  <option value="1">1 person</option>
                  <option value="2">2 people</option>
                  <option value="3">3 people</option>
                  <option value="4">4 people</option>
                  <option value="5">5 people</option>
                  <option value="6">6 people</option>
                  <option value="7">7 people</option>
                  <option value="8">8 people</option>
                  <option value="9">9 people</option>
                  <option value="10">10 people</option>
                  <option value="10+">10+ (large group)</option>
                </select>
              </div>

              <div>
                <label for="res-experience" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-1.5">What draws you to this experience?</label>
                <textarea
                  id="res-experience"
                  name="message"
                  rows={3}
                  placeholder="Tell us your fitness level, any questions, special needs, or what you're hoping to get out of it…"
                  class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white resize-none"
                ></textarea>
              </div>

              <!-- Contact preference -->
              <fieldset class="space-y-2">
                <legend class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-2">How would you like us to reach out? *</legend>

                <label class="flex items-start gap-3 p-3.5 rounded-xl border border-brand-primary/20 bg-brand-sky/20 cursor-pointer has-[:checked]:border-brand-primary has-[:checked]:bg-brand-sky/50 transition-colors">
                  <input type="radio" name="contact_preference" value="call" required class="mt-0.5 accent-brand-primary shrink-0" />
                  <div>
                    <span class="block text-sm font-semibold text-brand-dark">📞 Book a discovery call</span>
                    <span class="text-xs text-gray-500">We'll schedule a 10-min call at a time that suits you — our guide will walk you through everything.</span>
                  </div>
                </label>

                <label class="flex items-start gap-3 p-3.5 rounded-xl border border-brand-primary/20 bg-brand-sky/20 cursor-pointer has-[:checked]:border-brand-primary has-[:checked]:bg-brand-sky/50 transition-colors">
                  <input type="radio" name="contact_preference" value="callback" class="mt-0.5 accent-brand-primary shrink-0" />
                  <div>
                    <span class="block text-sm font-semibold text-brand-dark">💬 Have a guide contact me</span>
                    <span class="text-xs text-gray-500">One of our guides will reach out via WhatsApp or email at their earliest convenience — usually within 24 hours.</span>
                  </div>
                </label>
              </fieldset>

              <button
                type="submit"
                id="ev-submit-btn"
                class="w-full py-3.5 rounded-xl font-bold text-sm transition-colors duration-200 bg-brand-primary text-white hover:bg-brand-olive"
              >
                Send My Request →
              </button>

              <p class="text-center text-xs text-gray-400 leading-relaxed">
                Or reach us directly at
                <a href="tel:+96170050590" class="text-brand-primary hover:underline font-medium">+961 70-050590</a>
              </p>
            </form>

            <!-- Success message (shown after JS submit) -->
            <div id="reservation-success" class="hidden px-6 pb-8 text-center">
              <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17L4 12"/>
                </svg>
              </div>
              <h3 class="font-heading font-bold text-brand-primary text-lg mb-2">Request Sent!</h3>
              <p class="text-sm text-gray-600 leading-relaxed">
                Thank you! One of our guides will be in touch shortly about <strong id="ev-success-title"></strong> — either to confirm your call or reach out directly.
              </p>
              <p class="text-xs text-gray-400 mt-3">
                Questions in the meantime? Call <a href="tel:+96170050590" class="text-brand-primary hover:underline">+961 70-050590</a>
              </p>
            </div>

          </div>

          <!-- Contact alternative -->
          <div class="mt-4 text-center space-y-1">
            <p class="text-xs text-gray-500">
              Prefer to schedule directly?
              <a href="https://calendly.com/lebventures" target="_blank" rel="noopener noreferrer" class="text-brand-primary hover:underline font-semibold">Open Calendly →</a>
            </p>
            <p class="text-xs text-gray-400">
              Or reach us at <a href="tel:+96170050590" class="hover:underline">+961 70-050590</a> · <a href="mailto:lebventures.lebanon@gmail.com" class="hover:underline">lebventures.lebanon@gmail.com</a>
            </p>
          </div>
        </aside>

      </div>
    </div>

    <!-- Participant Reviews -->
    <div class="border-t border-brand-sky">
      <EventReviews eventId="" eventTitle="" eventDate="" />
    </div>

    <!-- Related events strip (back to all) -->
    <div class="bg-brand-sky/30 border-t border-brand-sky py-10 text-center">
      <p class="text-sm text-gray-600 mb-3">Looking for something different?</p>
      <a href="/events" class="btn-outline">Browse All Events</a>
    </div>

  </div>{/* closes #ev-content */}

  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ apiUrl }}>
(async () => {
  const id = window.location.pathname.replace(/^\/events\//, '').replace(/\/$/, '');
  if (!id || id === '_') {
    document.getElementById('ev-loading').classList.add('hidden');
    document.getElementById('ev-error').classList.remove('hidden');
    return;
  }
  const API = apiUrl || 'http://localhost:8000';
  try {
    const res = await fetch(`${API}/events/${id}`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const ev = await res.json();

    // Header
    document.getElementById('ev-title').textContent = ev.title ?? '';
    document.getElementById('ev-desc').textContent = ev.description ?? '';
    document.getElementById('ev-type-badge').textContent = ev.type ?? '';
    document.querySelectorAll('.ev-icon').forEach(el => {
      el.classList.toggle('hidden', el.dataset.type !== ev.type);
    });

    // Difficulty badge
    const diffBadge = document.getElementById('ev-diff-badge');
    const diffClasses = { easy: 'bg-green-100 text-green-700', moderate: 'bg-yellow-100 text-yellow-700', hard: 'bg-orange-100 text-orange-700', extreme: 'bg-red-100 text-red-700' };
    diffBadge.textContent = ev.difficulty ?? '';
    diffBadge.className = `text-xs font-bold px-2 py-0.5 rounded-full ${diffClasses[(ev.difficulty || '').toLowerCase()] ?? 'bg-gray-100 text-gray-600'}`;

    // Quick-info strip
    document.getElementById('ev-date').textContent = ev.date ? new Date(ev.date + 'T00:00:00').toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) : '';
    document.getElementById('ev-time').textContent = ev.time ?? '';
    document.getElementById('ev-location').textContent = ev.location ?? '';
    document.getElementById('ev-price').textContent = ev.price === 0 ? 'Free' : ev.price ? `$${ev.price}` : '';

    // Photo
    if (ev.image) {
      const img = document.getElementById('ev-photo');
      img.src = ev.image;
      img.alt = `${ev.title} — LebVentures`;
      document.getElementById('ev-photo-wrap').classList.remove('hidden');
    }
    // No image → leave photo section hidden (no placeholder)

    // Coords may be nested under ev.coords or flat on ev (legacy)
    const evLat = ev.coords?.lat ?? ev.lat;
    const evLng = ev.coords?.lng ?? ev.lng;

    // Map
    const mapEl = document.getElementById('event-map');
    if (evLat || evLng || ev.trailFile) {
      mapEl.dataset.lat = evLat ?? '';
      mapEl.dataset.lng = evLng ?? '';
      mapEl.dataset.title = ev.title ?? '';
      mapEl.dataset.location = ev.location ?? '';
      mapEl.dataset.trail = ev.trailFile ?? '';
      document.getElementById('ev-map-wrap').classList.remove('hidden');
      if (ev.trailFile) document.getElementById('ev-trail-note').classList.remove('hidden');
    }

    // Weather widget
    const widget = document.getElementById('weather-widget');
    widget.dataset.lat = evLat ?? '';
    widget.dataset.lng = evLng ?? '';
    widget.dataset.date = ev.date ?? '';
    widget.dataset.location = ev.location ?? '';
    document.getElementById('ev-weather-loc').textContent = ev.location ? `· ${ev.location}` : '';
    const wttrLink = document.getElementById('ev-wttr-link');
    if (wttrLink) { wttrLink.href = `https://wttr.in/${encodeURIComponent(ev.location ?? '')}`; wttrLink.textContent = `Check weather for ${ev.location ?? ''} →`; }

    // Highlights
    const ul = document.getElementById('ev-highlights');
    (ev.highlights ?? []).forEach(h => {
      ul.insertAdjacentHTML('beforeend', `<li class="flex items-start gap-3 p-3 rounded-xl bg-brand-sky/30 border border-brand-sky"><svg class="w-4 h-4 mt-0.5 shrink-0 text-brand-primary" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 3.5L6 11L2.5 7.5"/></svg><span class="text-sm text-brand-dark font-medium">${h}</span></li>`);
    });

    // Details
    const dl = document.getElementById('ev-details');
    [{ label: 'Guide', value: ev.guide }, { label: 'Group size', value: ev.spots ? `Max ${ev.spots} participants` : '' }, { label: 'Difficulty', value: ev.difficulty }, { label: 'Duration', value: ev.duration }, { label: 'Region', value: ev.region }]
      .filter(d => d.value)
      .forEach(({ label, value }) => dl.insertAdjacentHTML('beforeend', `<div class="p-4 rounded-xl border border-brand-sky bg-white"><dt class="text-xs font-bold text-brand-primary uppercase tracking-wider mb-1">${label}</dt><dd class="text-sm text-gray-700 font-medium">${value}</dd></div>`));
    if (evLat && evLng) {
      dl.insertAdjacentHTML('beforeend', `<div class="p-4 rounded-xl border border-brand-sky bg-white"><dt class="text-xs font-bold text-brand-primary uppercase tracking-wider mb-1">Meeting point</dt><dd class="text-sm font-medium"><a href="https://www.google.com/maps?q=${evLat},${evLng}" target="_blank" rel="noopener noreferrer" class="text-brand-primary hover:underline inline-flex items-center gap-1">📍 ${ev.location ?? ''}</a></dd></div>`);
    }

    // Availability
    const isFull = (ev.spotsLeft ?? 1) <= 0;
    const spotsPercent = ev.spots > 0 ? Math.round((ev.spotsLeft / ev.spots) * 100) : 0;
    document.getElementById('ev-avail-text').textContent = isFull ? 'This event is fully booked' : `${ev.spotsLeft} of ${ev.spots} spots remaining`;
    const pctEl = document.getElementById('ev-avail-pct');
    pctEl.textContent = isFull ? '0% available' : `${spotsPercent}% available`;
    pctEl.className = `text-sm font-bold ${isFull ? 'text-red-600' : spotsPercent <= 30 ? 'text-orange-500' : 'text-brand-primary'}`;
    const bar = document.getElementById('ev-avail-bar');
    bar.style.width = `${isFull ? 100 : 100 - spotsPercent}%`;
    bar.className = `h-2.5 rounded-full transition-all ${isFull ? 'bg-red-400' : spotsPercent <= 30 ? 'bg-orange-400' : 'bg-brand-primary'}`;
    if (isFull) document.getElementById('ev-full-badge').classList.remove('hidden');

    // Form
    document.getElementById('inp-event-id').value = ev.id;
    document.getElementById('inp-event-title').value = ev.title;
    document.getElementById('inp-event-date').value = ev.date ?? '';
    if (isFull) {
      document.getElementById('ev-form-title').textContent = 'Join the Waitlist';
      document.getElementById('ev-form-subtitle').textContent = "This event is full — leave your details and we'll notify you if a spot opens.";
      const btn = document.getElementById('ev-submit-btn');
      btn.textContent = 'Join Waitlist →';
      btn.className = 'w-full py-3.5 rounded-xl font-bold text-sm transition-colors duration-200 bg-brand-gold text-brand-dark hover:bg-yellow-400';
      document.getElementById('ev-price-row').classList.add('hidden');
    } else {
      document.getElementById('ev-form-subtitle').textContent = `Secure your place for ${ev.title}.`;
      document.getElementById('ev-price-display').textContent = ev.price === 0 ? 'Free' : `$${ev.price}`;
    }
    const successTitle = document.getElementById('ev-success-title');
    if (successTitle) successTitle.textContent = ev.title;

    // Hide reservation form for past events
    const isPastEvent = new Date(ev.date + 'T23:59:59') < new Date();
    if (isPastEvent) {
      const aside = document.getElementById('ev-reservation-aside');
      if (aside) {
        aside.innerHTML = `<div class="bg-brand-sky/20 rounded-3xl border border-brand-sky p-8 text-center">
          <div class="text-4xl mb-3">🏔️</div>
          <h3 class="font-heading font-bold text-brand-primary text-lg mb-2">This adventure has ended</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Bookings for this event are closed. Browse upcoming events to join your next adventure.</p>
          <a href="/events" class="inline-block mt-5 px-5 py-2.5 rounded-xl bg-brand-primary text-white text-sm font-semibold hover:bg-brand-olive transition-colors">Browse Upcoming Events →</a>
        </div>`;
      }
    }

    document.title = `${ev.title} — LebVentures`;
    document.getElementById('ev-loading').classList.add('hidden');
    document.getElementById('ev-content').classList.remove('hidden');
    document.dispatchEvent(new CustomEvent('ev:loaded', { detail: ev }));
  } catch (err) {
    console.error(err);
    document.getElementById('ev-loading').classList.add('hidden');
    document.getElementById('ev-error').classList.remove('hidden');
  }
})();
</script>

<script>
  const form = document.getElementById('reservation-form') as HTMLFormElement | null;
  const success = document.getElementById('reservation-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }
    const submitBtn = document.getElementById('ev-submit-btn') as HTMLButtonElement | null;
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }
    const fd = new FormData(form);
    const body = {
      name:           fd.get('name'),
      email:          fd.get('email'),
      phone:          fd.get('phone') || undefined,
      numberOfPeople: Number(fd.get('group_size')) || 1,
      notes:          fd.get('message') || undefined,
    };
    const API = (document.getElementById('inp-event-id') as HTMLInputElement)?.getAttribute('data-api') || import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
    try {
      const res = await fetch(`${API}/events/${fd.get('event_id')}/subscribe`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error(await res.text());
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch (err) {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send My Request →'; }
      alert('Something went wrong. Please try again.');
      console.error(err);
    }
  });
</script>

<!-- ── Weather Forecast (Open-Meteo, no API key) ───────────────── -->
<script type="module" is:inline>
  async function runWeather() {
    const widget = document.getElementById('weather-widget');
    const loading = document.getElementById('weather-loading');
    const content = document.getElementById('weather-content');
    const errEl   = document.getElementById('weather-error');
    if (!widget) return;

    let lat  = parseFloat(widget.dataset.lat);
    let lng  = parseFloat(widget.dataset.lng);
    const date = widget.dataset.date;
    const loc  = widget.dataset.location;

    const validCoords = isFinite(lat) && isFinite(lng) && lat !== 0 && lng !== 0;
    if (!validCoords) {
      const waitForTrail = () => new Promise(resolve => {
        if (window._trailStartLat) { resolve(true); return; }
        let tries = 0;
        const iv = setInterval(() => { tries++; if (window._trailStartLat || tries > 30) { clearInterval(iv); resolve(!!window._trailStartLat); } }, 200);
      });
      const gotTrail = await waitForTrail();
      if (gotTrail) {
        lat = window._trailStartLat;
        lng = window._trailStartLng;
      } else {
        const queries = [loc, loc.split(' ')[0] + ' Lebanon', 'Beirut'];
        let found = false;
        for (const q of queries) {
          try {
            const geoRes = await fetch(`https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(q)}&count=1&language=en&format=json`);
            const geoData = await geoRes.json();
            if (geoData.results && geoData.results.length > 0) { lat = geoData.results[0].latitude; lng = geoData.results[0].longitude; found = true; break; }
          } catch { /* continue */ }
        }
        if (!found) { lat = 33.8938; lng = 35.5018; }
      }
    }

    function wmoInfo(code) {
      if (code === 0)  return { icon: '☀️',  label: 'Clear' };
      if (code <= 3)   return { icon: '⛅',  label: 'Partly cloudy' };
      if (code <= 48)  return { icon: '🌫️', label: 'Foggy' };
      if (code <= 55)  return { icon: '🌦️', label: 'Drizzle' };
      if (code <= 67)  return { icon: '🌧️', label: 'Rain' };
      if (code <= 77)  return { icon: '🌨️', label: 'Snow' };
      if (code <= 82)  return { icon: '🌦️', label: 'Showers' };
      if (code <= 99)  return { icon: '⛈️', label: 'Storm' };
      return { icon: '🌡️', label: 'N/A' };
    }

    try {
      const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_probability_max,windspeed_10m_max&timezone=Asia%2FBeirut&forecast_days=7`;
      const res  = await fetch(url);
      if (!res.ok) throw new Error('api error');
      const data = await res.json();
      const days = data.daily.time;
      const eventIdx = days.indexOf(date);
      let cards = '';
      days.forEach((day, i) => {
        const isEvent = day === date;
        const { icon, label } = wmoInfo(data.daily.weathercode[i]);
        const dayLabel = new Date(day + 'T00:00:00').toLocaleDateString('en-GB', { weekday: 'short' });
        const dayNum   = new Date(day + 'T00:00:00').getDate();
        const precip   = data.daily.precipitation_probability_max[i];
        const tMax     = Math.round(data.daily.temperature_2m_max[i]);
        const tMin     = Math.round(data.daily.temperature_2m_min[i]);
        const base  = isEvent ? 'bg-brand-primary text-white ring-2 ring-brand-primary ring-offset-1' : 'bg-brand-sky/30 text-brand-dark hover:bg-brand-sky/60';
        const sub   = isEvent ? 'text-white/60' : 'text-gray-400';
        const label2 = isEvent ? 'text-brand-gold font-bold' : 'text-gray-500 font-bold';
        cards += `<div class="flex flex-col items-center p-2 rounded-xl text-center transition-colors ${base}"><div class="text-[0.6rem] uppercase tracking-wider ${label2}">${dayLabel}</div><div class="text-[0.55rem] mb-1 ${sub}">${dayNum}</div><div class="text-2xl my-1 leading-none">${icon}</div><div class="text-[0.55rem] font-semibold leading-tight">${label}</div><div class="font-bold text-xs mt-1">${tMax}°C</div><div class="text-[0.6rem] ${sub}">${tMin}°C</div>${precip > 20 ? `<div class="text-[0.55rem] mt-0.5 ${isEvent ? 'text-blue-200' : 'text-blue-500'}">💧${precip}%</div>` : ''}</div>`;
      });
      const windNote = eventIdx >= 0 ? `Event date highlighted · Wind: ${Math.round(data.daily.windspeed_10m_max[eventIdx])} km/h` : 'Event date beyond 7-day forecast — showing current conditions';
      content.innerHTML = `<div class="grid grid-cols-7 gap-1.5">${cards}</div><p class="text-[0.65rem] text-gray-400 text-center mt-3">${windNote} · <a href="https://open-meteo.com" target="_blank" rel="noopener noreferrer" class="hover:underline">Open-Meteo</a></p>`;
      loading.classList.add('hidden');
      content.classList.remove('hidden');
    } catch {
      loading.classList.add('hidden');
      errEl.classList.remove('hidden');
    }
  }
  document.addEventListener('ev:loaded', runWeather);
</script>

