---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const timeline = [
  { year: 'The Beginning', event: 'Pierre Abboud and Gioia Wehbe meet through a shared love of Lebanon\'s outdoors. Their passion for nature, adventure, and community becomes the foundation of a lifelong partnership.' },
  { year: 'Certifications', event: 'Both pursue formal certifications in Wilderness First Aid, navigation, rope safety, and sustainable tourism guiding — staying current with ongoing training each year.' },
  { year: '2019', event: 'LebVentures launches from Byblos with its first guided adventures. A small community of nature lovers quickly grows into a movement for inclusive, authentic outdoor experiences across Lebanon.' },
  { year: 'Expanding', event: 'LebVentures grows its offerings to 9+ adventure types — from land and water to winter excursions and kids educational experiences — while deepening partnerships with local communities and artisans.' },
  { year: 'Today', event: 'With 20+ events delivered and 100+ adventurers guided, LebVentures continues to expand. Pierre and Gioia remain hands-on, certified, and out on the trail every week — for the love of nature.' },
];
---

<BaseLayout
  title="About LebVentures — Pierre Abboud & Gioia Wehbe"
  description="Meet Pierre Abboud and Gioia Wehbe, the scout alumni couple behind LebVentures — a family-founded adventure tour operator based in Byblos, Lebanon, rooted in a lifelong love for the outdoors."
  keywords="LebVentures founders, Pierre Abboud, Gioia Wehbe, Lebanese scouts, about LebVentures, adventure guides Lebanon, sustainable tourism Byblos Lebanon"
>
  <Navbar />
  <main>
    <Hero
      tagline="Our Story"
      heading="Family-Founded,<br />Adventure-Driven"
      subheading="A shared passion for Lebanon's mountains turned into a mission: connecting adventurers with the country's hidden trails, sacred cedars, and breathtaking landscapes."
    />

    <About />

    <!-- Founders timeline -->
    <section class="py-20 bg-brand-sky/30" aria-labelledby="timeline-heading">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 id="timeline-heading" class="section-heading">Our Journey</h2>
          <p class="section-subheading mx-auto">From scout meetings to mountain guides — the story behind LebVentures.</p>
        </div>
        <ol class="relative border-l-2 border-brand-primary space-y-10 ml-4">
          {timeline.map((item, i) => (
            <li class="ml-6">
              <span class="absolute -left-3.5 flex h-7 w-7 items-center justify-center rounded-full bg-brand-primary text-white text-xs font-bold ring-4 ring-white">
                {i + 1}
              </span>
              <div class="flex flex-col gap-1">
                <span class="inline-block bg-brand-gold text-brand-dark text-xs font-bold px-2 py-0.5 rounded w-fit">{item.year}</span>
                <p class="text-gray-700 text-sm leading-relaxed mt-1">{item.event}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-white text-center">
      <div class="max-w-xl mx-auto px-4">
        <h2 class="section-heading">Ready to Join Us?</h2>
        <p class="section-subheading mx-auto mb-8">Every adventure with LebVentures is guided by the same values that shaped our founders — respect, community, and love for the wild.</p>
        <a href="/contact" class="btn-primary px-10 py-4 text-base">Book an Experience</a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
