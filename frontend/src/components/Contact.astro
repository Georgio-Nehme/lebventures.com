---
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
---

<section id="contact" class="py-20 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block text-xs font-bold text-brand-primary uppercase tracking-widest mb-3">Get in Touch</span>
      <h2 class="section-heading">Ready to Venture Out?</h2>
      <p class="section-subheading mx-auto">
        Tell us about the adventure you're dreaming of and we'll craft the perfect experience for you.
      </p>
    </div>

    <form
      id="contact-form"
      class="bg-brand-sky/30 rounded-3xl p-8 md:p-10 shadow-sm border border-brand-sky space-y-6"
      novalidate
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label for="name" class="block text-sm font-semibold text-brand-dark mb-1.5">Your Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Maya Khoury"
            class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-semibold text-brand-dark mb-1.5">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="maya@example.com"
            class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white"
          />
        </div>
      </div>

      <div>
        <label for="adventure" class="block text-sm font-semibold text-brand-dark mb-1.5">Adventure Type</label>
        <select
          id="adventure"
          name="adventure"
          class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white"
        >
          <option value="">Select an experience...</option>
          <optgroup label="Land Adventures">
            <option>Hiking &amp; Trekking</option>
            <option>Rock Climbing</option>
            <option>Camping Expedition</option>
            <option>Mountain Biking</option>
            <option>Caving</option>
          </optgroup>
          <optgroup label="Water Activities">
            <option>Kayaking</option>
            <option>Snorkeling</option>
            <option>Fishing</option>
          </optgroup>
          <optgroup label="Winter Experiences">
            <option>Snowshoeing</option>
          </optgroup>
          <optgroup label="Leisure &amp; Exploration">
            <option>Stargazing &amp; Camping</option>
            <option>Archery &amp; Picnicking</option>
            <option>Heritage &amp; Sightseeing</option>
          </optgroup>
          <optgroup label="Kids &amp; Family">
            <option>Kids Educational &amp; Sensory Adventure</option>
            <option>Family Hike</option>
          </optgroup>
          <option value="corporate">Corporate Team Building</option>
          <option value="custom">Custom / Not Sure Yet</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-semibold text-brand-dark mb-1.5">Tell Us More</label>
        <textarea
          id="message"
          name="message"
          rows={4}
          placeholder="Group size, preferred dates, experience level, any questions..."
          class="w-full rounded-xl border border-brand-primary/30 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white resize-none"
        ></textarea>
      </div>

      <div id="contact-error" class="hidden rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        Something went wrong — please try again or reach us directly at
        <a href="mailto:lebventures.lebanon@gmail.com" class="font-semibold underline">lebventures.lebanon@gmail.com</a>.
      </div>

      <button
        type="submit"
        id="contact-submit"
        class="w-full btn-primary text-center py-4 text-base"
      >
        Send My Request
      </button>
    </form>

    <!-- Success state -->
    <div id="contact-success" class="hidden bg-brand-sky/30 rounded-3xl p-8 md:p-10 shadow-sm border border-brand-sky text-center">
      <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6L9 17L4 12"/>
        </svg>
      </div>
      <h3 class="font-heading font-bold text-brand-primary text-xl mb-2">Message Received!</h3>
      <p class="text-gray-600 text-sm leading-relaxed">
        Thanks for reaching out! One of our guides will be in touch within 24 hours.
      </p>
      <p class="text-xs text-gray-400 mt-3">
        Or reach us directly at
        <a href="tel:+96170050590" class="text-brand-primary hover:underline">+961 70-050590</a> ·
        <a href="mailto:lebventures.lebanon@gmail.com" class="text-brand-primary hover:underline">lebventures.lebanon@gmail.com</a>
      </p>
    </div>

  </div>
</section>

<script define:vars={{ apiUrl }}>
  const form    = document.getElementById('contact-form');
  const success = document.getElementById('contact-success');
  const errBox  = document.getElementById('contact-error');
  const btn     = document.getElementById('contact-submit');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    btn.disabled = true;
    btn.textContent = 'Sending…';
    errBox.classList.add('hidden');

    const fd = new FormData(form);
    const body = {
      name:      fd.get('name'),
      email:     fd.get('email'),
      adventure: fd.get('adventure') || undefined,
      message:   fd.get('message')   || undefined,
    };

    try {
      const res = await fetch(`${apiUrl}/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      form.classList.add('hidden');
      success.classList.remove('hidden');
    } catch {
      errBox.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send My Request';
    }
  });
</script>
