---
import Icon from './Icon.astro';

const pillars = [
  {
    icon: 'leaf',
    title: 'Leave No Trace',
    description: 'Every trip follows strict LNT principles. We pack out what we pack in and educate our community on responsible outdoor ethics.',
  },
  {
    icon: 'house',
    title: 'Support Local Communities',
    description: 'We source food, guides, and accommodation from local villages, ensuring tourism income directly benefits the people of Lebanon.',
  },
  {
    icon: 'cedar',
    title: 'Protect Natural Habitats',
    description: 'From the cedars of God to the Chouf Biosphere Reserve, we partner with conservation bodies to protect Lebanon\'s ecosystems.',
  },
  {
    icon: 'book',
    title: 'Education First',
    description: 'Our guides are trained naturalists who share knowledge about local flora, fauna, geology, and the stories embedded in the land.',
  },
];
---

<section id="sustainable-tourism" class="py-20 bg-brand-sky/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Text side -->
      <div>
        <span class="inline-block text-xs font-bold text-brand-primary uppercase tracking-widest mb-3">Our Commitment</span>
        <h2 class="section-heading">Sustainable Tourism at Our Core</h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          LebVentures was built on the belief that adventure and environmental stewardship go hand in hand. Every decision we make — from route selection to supplier partnerships — is guided by sustainability and respect for Lebanon's natural heritage.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {pillars.map(p => (
            <div class="flex gap-4">
              <div class="text-brand-primary shrink-0 mt-0.5">
                <Icon name={p.icon} class="w-10 h-10" />
              </div>
              <div>
                <h4 class="font-heading font-bold text-brand-primary text-base mb-1">{p.title}</h4>
                <p class="text-sm text-gray-600 leading-relaxed">{p.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Visual side -->
      <div class="relative">
        <div class="bg-brand-primary rounded-3xl p-10 text-white text-center shadow-2xl">
          <div class="flex justify-center mb-6 opacity-80">
            <Icon name="mountain" class="w-20 h-20 text-white" />
          </div>
          <blockquote class="text-xl font-heading italic leading-relaxed mb-6">
            "The mountains of Lebanon are not just scenery — they are living history, sacred ground, and a responsibility."
          </blockquote>
          <div class="flex items-center justify-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-gold flex items-center justify-center text-brand-dark font-bold text-sm">
              LV
            </div>
            <div class="text-left">
              <div class="font-bold text-sm">LebVentures Founders</div>
              <div class="text-brand-sky text-xs">Scout Alumni & Nature Advocates</div>
            </div>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 rounded-full bg-brand-gold/20 -z-10"></div>
        <div class="absolute -top-4 -left-4 w-16 h-16 rounded-full bg-brand-lime/30 -z-10"></div>
      </div>
    </div>
  </div>
</section>
