---
interface Props {
  limit?: number;
  showAll?: boolean;
}

const { limit, showAll = true } = Astro.props;
const apiUrl = import.meta.env.PUBLIC_API_URL;
---

<section id="events" class="py-20 bg-brand-sky/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <span class="inline-block text-xs font-bold text-brand-primary uppercase tracking-widest mb-3">What's Coming Up</span>
      <h2 class="section-heading">Upcoming Events</h2>
      <p class="section-subheading mx-auto">
        Join a scheduled adventure or workshop. All trips are small-group and led by our certified founders.
      </p>
    </div>

    <!-- Loading skeleton -->
    <div id="events-loading" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {Array.from({ length: limit ?? 3 }).map(() => (
        <div class="bg-white rounded-2xl border border-brand-sky overflow-hidden animate-pulse">
          <div class="h-48 bg-gray-200" />
          <div class="px-5 py-4 space-y-3">
            <div class="h-4 bg-gray-200 rounded w-3/4" />
            <div class="h-3 bg-gray-200 rounded w-1/2" />
            <div class="h-3 bg-gray-200 rounded w-full" />
            <div class="h-3 bg-gray-200 rounded w-5/6" />
            <div class="h-10 bg-gray-200 rounded-xl mt-4" />
          </div>
        </div>
      ))}
    </div>

    <div id="events-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 hidden"></div>
    <div id="events-empty" class="text-center py-16 text-gray-500 hidden">No upcoming events at this time. Check back soon!</div>
    <div id="events-error" class="text-center py-16 text-red-500 hidden">Failed to load events. Please refresh the page.</div>

    {showAll && (
      <div id="events-viewall" class="text-center mt-12 hidden">
        <a href="/events" class="btn-outline">View All Events</a>
      </div>
    )}

  </div>
</section>

<script define:vars={{ apiUrl, limit, showAll }}>
  const difficultyColor = {
    Easy: 'bg-green-100 text-green-800',
    Moderate: 'bg-yellow-100 text-yellow-800',
    Challenging: 'bg-orange-100 text-orange-800',
    Expert: 'bg-red-100 text-red-800',
  };

  function formatMonth(iso) {
    return new Date(iso + 'T00:00:00').toLocaleDateString('en-GB', { month: 'short' }).toUpperCase();
  }
  function formatDay(iso) {
    return new Date(iso + 'T00:00:00').getDate();
  }
  function spotsClass(left, total) {
    const pct = left / total;
    if (pct === 0) return 'text-red-600';
    if (pct <= 0.3) return 'text-orange-500';
    return 'text-brand-primary';
  }

  function renderCard(event) {
    const fullyBooked = event.spotsLeft === 0;
    const dc = difficultyColor[event.difficulty] ?? 'bg-gray-100 text-gray-800';
    const sc = spotsClass(event.spotsLeft, event.spots);
    const spotsText = fullyBooked ? 'Fully booked' : `${event.spotsLeft} spot${event.spotsLeft === 1 ? '' : 's'} left`;
    const priceText = event.price === 0 ? 'Free' : `$${event.price}`;

    const header = event.image
      ? `<div class="relative h-48 overflow-hidden shrink-0">
          <img src="${event.image}" alt="${event.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/85 via-brand-dark/30 to-transparent"></div>
          <div class="absolute top-3 left-3 bg-white rounded-xl w-14 text-center py-1.5 shadow-md">
            <div class="text-[0.6rem] font-bold text-brand-primary uppercase tracking-widest leading-none">${formatMonth(event.date)}</div>
            <div class="text-2xl font-heading font-bold text-brand-dark leading-none mt-0.5">${formatDay(event.date)}</div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 px-4 pb-3">
            <span class="text-xs font-semibold text-white/70 capitalize">${event.type}</span>
            <h3 class="font-heading font-bold text-white text-base leading-tight truncate">${event.title}</h3>
          </div>
        </div>`
      : `<div class="bg-brand-primary px-5 py-4 flex items-center gap-4 shrink-0">
          <div class="shrink-0 bg-white rounded-xl w-14 text-center py-1.5 shadow-sm">
            <div class="text-[0.6rem] font-bold text-brand-primary uppercase tracking-widest leading-none">${formatMonth(event.date)}</div>
            <div class="text-2xl font-heading font-bold text-brand-dark leading-none mt-0.5">${formatDay(event.date)}</div>
          </div>
          <div class="flex-1 min-w-0">
            <span class="text-xs font-semibold text-white/70 capitalize">${event.type}</span>
            <h3 class="font-heading font-bold text-white text-base leading-tight truncate">${event.title}</h3>
          </div>
        </div>`;

    const highlights = (event.highlights ?? []).slice(0, 3).map(h =>
      `<li class="flex items-start gap-2 text-xs text-gray-600">
        <svg class="w-3.5 h-3.5 mt-0.5 shrink-0 text-brand-lime" viewBox="0 0 16 16" fill="currentColor">
          <path d="M13.5 3.5L6 11L2.5 7.5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>${h}</li>`
    ).join('');

    return `<article class="group bg-white rounded-2xl border border-brand-sky overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
      ${header}
      <div class="px-5 py-4 flex flex-col flex-1 gap-3">
        <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500">
          <span>${event.time} · ${event.duration}</span>
          <span>${event.location}</span>
        </div>
        <p class="text-sm text-gray-600 leading-relaxed line-clamp-3 flex-1">${event.description}</p>
        <ul class="space-y-1">${highlights}</ul>
        <div class="flex items-center justify-between pt-3 border-t border-brand-sky mt-auto">
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold px-2 py-0.5 rounded-full ${dc}">${event.difficulty}</span>
            <span class="text-xs font-semibold ${sc}">${spotsText}</span>
          </div>
          <div class="text-right">
            <span class="text-lg font-heading font-bold text-brand-primary">${priceText}</span>
            ${event.price > 0 ? '<span class="text-xs text-gray-400 block leading-none">per person</span>' : ''}
          </div>
        </div>
        <a href="${fullyBooked ? '#' : `/events/${event.id}`}"
          class="w-full text-center text-sm font-bold py-2.5 rounded-xl transition-colors duration-200 ${fullyBooked ? 'bg-gray-100 text-gray-400 cursor-not-allowed pointer-events-none' : 'bg-brand-primary text-white hover:bg-brand-olive'}">
          ${fullyBooked ? 'Fully Booked' : 'Reserve My Spot →'}
        </a>
      </div>
    </article>`;
  }

  async function loadEvents() {
    const loading = document.getElementById('events-loading');
    const grid = document.getElementById('events-grid');
    const empty = document.getElementById('events-empty');
    const error = document.getElementById('events-error');
    const viewall = document.getElementById('events-viewall');

    try {
      const res = await fetch(`${apiUrl}/events`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      let events = await res.json();
      events = events.map(e => ({
        ...e,
        lat: e.coords?.lat ? parseFloat(e.coords.lat) : undefined,
        lng: e.coords?.lng ? parseFloat(e.coords.lng) : undefined,
      }));

      // Keep only upcoming events and sort by date ascending
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      events = events
        .filter(e => e.date && new Date(e.date + 'T00:00:00') >= today)
        .sort((a, b) => a.date.localeCompare(b.date));

      loading.classList.add('hidden');

      if (events.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      const visible = limit ? events.slice(0, limit) : events;
      grid.innerHTML = visible.map(renderCard).join('');
      grid.classList.remove('hidden');

      if (showAll && limit && events.length > limit) {
        viewall.classList.remove('hidden');
      }
    } catch (err) {
      console.error('Failed to load events:', err);
      loading.classList.add('hidden');
      error.classList.remove('hidden');
    }
  }

  loadEvents();
</script>
