# Copy this file to .env and fill in your values after deploying the AWS stack.
# Run `sam deploy` in the /backend folder and copy the Outputs into this file.

# Public API Gateway endpoint (from SAM output: ApiUrl)
PUBLIC_API_URL=https://xxxxxxxxxx.execute-api.eu-west-1.amazonaws.com

# Cognito User Pool ID (from SAM output: UserPoolId)
PUBLIC_COGNITO_POOL_ID=eu-west-1_XXXXXXXXX

# Cognito App Client ID (from SAM output: UserPoolClientId)
PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
